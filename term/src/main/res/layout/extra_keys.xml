<?xml version="1.0" encoding="utf-8"?>
<HorizontalScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/extra_keys_scroll"
    android:layout_width="match_parent"
    android:layout_height="40dp"
    android:background="#222222"
    android:scrollbars="none"
    android:visibility="gone">

    <LinearLayout
        android:id="@+id/extra_keys_container"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <Button
            android:id="@+id/key_esc"
            style="@style/ExtraKeyButton"
            android:text="ESC" />
        <Button
            android:id="@+id/key_ctrl"
            style="@style/ExtraKeyButton"
            android:text="CTRL" />
        <Button
            android:id="@+id/key_alt"
            style="@style/ExtraKeyButton"
            android:text="ALT" />
        <Button
            android:id="@+id/key_tab"
            style="@style/ExtraKeyButton"
            android:text="TAB" />
        <Button
            android:id="@+id/key_minus"
            style="@style/ExtraKeyButton"
            android:text="-" />
        <Button
            android:id="@+id/key_slash"
            style="@style/ExtraKeyButton"
            android:text="/" />
        <Button
            android:id="@+id/key_left"
            style="@style/ExtraKeyButton"
            android:text="←" />
        <Button
            android:id="@+id/key_down"
            style="@style/ExtraKeyButton"
            android:text="↓" />
        <Button
            android:id="@+id/key_up"
            style="@style/ExtraKeyButton"
            android:text="↑" />
        <Button
            android:id="@+id/key_right"
            style="@style/ExtraKeyButton"
            android:text="→" />

    </LinearLayout>
</HorizontalScrollView>
